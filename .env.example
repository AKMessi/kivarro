# Optional local inference backend paths.
# Copy this file to .env for local development if you do not keep backends on PATH.

# Windows example:
# KIVARRO_LLAMA_SERVER=C:\path\to\llama-server.exe
# KIVARRO_MISTRALRS=C:\path\to\mistralrs.exe

# macOS/Linux example:
# KIVARRO_LLAMA_SERVER=/path/to/llama-server
# KIVARRO_MISTRALRS=/path/to/mistralrs

# Initial/default local API port when no saved app setting exists.
KIVARRO_API_PORT=8080
